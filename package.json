{
  "name": "marketplace-platform-server",
  "version": "1.0.0",
  "description": "Express API for PromptGrowth — AI prompt marketplace (auth, prompts, JWT cookies, MongoDB)",
  "main": "server.js",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "seed": "node src/scripts/seed.js",
    "seed:admin": "node src/scripts/seed-real-admin.js",
    "health": "node -e \"require('http').get('http://localhost:' + (process.env.PORT || 5000) + '/api/health', (r) => { let d = ''; r.on('data', (c) => d += c); r.on('end', () => console.log(d)); }).on('error', (e) => { console.error(e.message); process.exit(1); })\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomalahmed/Marketplace-Platform-Server.git"
  },
  "bugs": {
    "url": "https://github.com/tomalahmed/Marketplace-Platform-Server/issues"
  },
  "homepage": "https://github.com/tomalahmed/Marketplace-Platform-Server#readme",
  "keywords": [
    "express",
    "mongodb",
    "mongoose",
    "jwt",
    "marketplace",
    "ai-prompts",
    "promptgrowth",
    "rest-api"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "src"
    ],
    "ext": "js,json",
    "ignore": [
      "src/data/**",
      "node_modules/**"
    ]
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "firebase-admin": "^14.1.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.2",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
