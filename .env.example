PORT=5000
NODE_ENV=production
MONGODB_URI=
JWT_SECRET=
JWT_EXPIRES_IN=7d
CLIENT_URL=https://your-frontend-domain.com

# Stripe (required for Premium payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_CENTS=500

# Firebase Admin — required for Google sign-in in production
# Use the same project as NEXT_PUBLIC_FIREBASE_* on the client
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Platform admin (run once: npm run seed:admin)
REAL_ADMIN_EMAIL=
REAL_ADMIN_PASSWORD=
REAL_ADMIN_NAME=PromptGrowth Admin

# Optional
COOKIE_SAME_SITE=lax
ENABLE_DEMO=false
